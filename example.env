# Project root .env template.
# Copy to .env and fill in values. Both backend and frontend read this file:
#   - backend (dotenv) via path.resolve('../.env') from backend/src/config/env.js
#   - frontend (Vite) via envDir: '..' in frontend/vite.config.ts
# See docs/guides/environment-variables.md for the full reference.

# ── MongoDB ────────────────────────────────────────────────────────────────
# Primary cluster (operational data). Required; backend exits on connect fail.
MONGO_URI=
# Secondary cluster (partner schools + certificate lookup). Required —
# secondaryConnection.js throws synchronously at import time if missing.
MONGO_URI2=

# ── Backend HTTP / runtime ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# CORS_ORIGIN is read into env.corsOrigin but app.js currently hard-codes
# origin:true. Setting this has no effect today.
CORS_ORIGIN=*

# ── JWT ────────────────────────────────────────────────────────────────────
# Use long random strings in production. Rotating these forces all users to
# re-login.
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=
# ⚠ The env-var name has a typo (EXIRES not EXPIRES). The backend reads
# process.env.JWT_REFRESH_EXIRES_IN — match it verbatim.
JWT_REFRESH_EXIRES_IN=7d

# ── Frontend ───────────────────────────────────────────────────────────────
# Must be a URL the browser can reach. http:// is auto-prefixed if missing.
VITE_API_URL=http://localhost:3000/api

# ── Misc ───────────────────────────────────────────────────────────────────
# Reserved for future feature flags. Set to 1 to flip env.isLocal=true.
LOCAL=1
